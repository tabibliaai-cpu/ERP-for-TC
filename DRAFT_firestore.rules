rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitive Definitions ---
    
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Fetch user profile from global users collection
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // Role helpers
    function isTenantAdmin(tenantId) {
      let data = getUserData(request.auth.uid);
      return data.tenantId == tenantId && data.role == 'admin';
    }

    function isMember(tenantId) {
      return getUserData(request.auth.uid).tenantId == tenantId;
    }

    // --- PHASE 4: Validation Blueprints ---

    function isValidInstitution(data) {
      return data.keys().hasAll(['name', 'subdomain', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.subdomain is string && data.subdomain.size() > 0 && data.subdomain.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'tenantId', 'role', 'displayName']) &&
             data.keys().size() >= 4 &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'faculty', 'student', 'accountant', 'librarian'] &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidRecord(data, tenantId) {
      return data.keys().hasAll(['tenantId', 'module', 'ciphertext', 'iv', 'authorId', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.tenantId == tenantId &&
             data.authorId == request.auth.uid &&
             data.ciphertext is string && data.ciphertext.size() <= 500000 &&
             data.iv is string && data.iv.size() <= 128 &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'ciphertext', 'iv', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.senderId == request.auth.uid &&
             data.ciphertext is string && data.ciphertext.size() <= 100000 &&
             data.createdAt == request.time;
    }

    // --- MATCH BLOCKS ---

    // 1. Tenants Collection
    match /tenants/{tenantId} {
      allow get: if isVerified();
      // Only platform Super Admins (defined via email for bootstrap) can create tenants
      allow create: if isVerified() && request.auth.token.email == 'dasucosmos@gmail.com' && isValidInstitution(incoming());
      
      // 2. Records Sub-collection
      match /records/{recordId} {
        allow list: if isVerified() && isMember(tenantId) && existing().tenantId == tenantId;
        allow get: if isVerified() && isMember(tenantId);
        allow create: if isVerified() && isMember(tenantId) && isValidId(recordId) && isValidRecord(incoming(), tenantId);
        
        allow update: if isVerified() && isMember(tenantId) && (
          // Action: Edit Content
          (incoming().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['ciphertext', 'iv', 'updatedAt']))
        );
        allow delete: if isVerified() && (isTenantAdmin(tenantId) || existing().authorId == request.auth.uid);
      }
    }

    // 3. User Profiles
    match /users/{userId} {
      allow get: if isVerified() && (request.auth.uid == userId || isMember(getUserData(userId).tenantId));
      allow list: if isVerified() && isMember(resource.data.tenantId);
      
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'publicKey']);
    }

    // 4. Encrypted Messaging
    match /chats/{chatId}/messages/{messageId} {
      // Chat accessibility should be derived from participants but for demo purposes:
      allow read: if isVerified() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow create: if isVerified() && isValidId(messageId) && isValidMessage(incoming());
    }
  }
}
